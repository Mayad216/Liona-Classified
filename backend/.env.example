APP_NAME=Khaleej
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Dubai
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Use SQLite for the fastest local setup; switch to mysql for production.
DB_CONNECTION=sqlite
# For MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=khaleej
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@khaleej.ae"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum / CORS — point this at the React frontend
SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173

# Resume builder AI (optional — local fallbacks work without a key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
RESUME_AI_DAILY_LIMIT=20
RESUME_FREE_WATERMARK=true

# Jobs Copilot — Stripe (optional; demo checkout works without keys)
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_MAX_MONTHLY=
STRIPE_PRICE_MAX_YEARLY=
STRIPE_PRICE_AUTO_25=
STRIPE_PRICE_AUTO_100=
STRIPE_PRICE_AUTO_250=
COPILOT_STRIPE_SUCCESS_URL=http://localhost:5173/jobs/copilot/billing/success
COPILOT_STRIPE_CANCEL_URL=http://localhost:5173/jobs/copilot/billing
COPILOT_OPENAI_MODEL=gpt-4o-mini
COPILOT_RESUME_DISK=local
COPILOT_RESUME_MAX_KB=5120
COPILOT_AUTO_APPLY_MODE=demo
COPILOT_AUTO_APPLY_MIN_SCORE=50
COPILOT_AUTO_APPLY_CONFIDENCE=0.75
COPILOT_AUTO_APPLY_WORKER_URL=http://localhost:3100
COPILOT_AUTO_APPLY_WORKER_SECRET=change-me-worker-secret
COPILOT_DAILY_DIGEST=true
COPILOT_DAILY_DIGEST_HOUR=8
COPILOT_SCREENSHOT_DISK=local
COPILOT_EMBEDDINGS_ENABLED=true
COPILOT_EMBEDDING_MODEL=text-embedding-3-small
COPILOT_EMBEDDING_BLEND=0.3
COPILOT_SCRAPING_ENABLED=true
